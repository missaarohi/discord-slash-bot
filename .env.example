# Django
DEBUG=True
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_HOSTS=127.0.0.1,localhost,your-app.onrender.com
CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com

# Database (Neon / Supabase free Postgres). Leave blank to fall back to local sqlite for dev.
DATABASE_URL=postgres://user:password@host:5432/dbname

# Discord Developer Portal -> your application
DISCORD_PUBLIC_KEY=your-application-public-key
DISCORD_BOT_TOKEN=your-bot-token
DISCORD_APPLICATION_ID=your-application-id

# Optional - only needed if you turn on the AI summarize stretch goal.
# Get a free key at https://console.groq.com (no credit card).
GROQ_API_KEY=
